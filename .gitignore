# === Python Examples (Execution & Cache) ===
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# === Node.js / TypeScript Examples ===
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
dist/
out/
coverage/
.next/
.nuxt/

# === Virtual Environments (Avoid committing local venvs) ===
.venv
.venv/
env/
venv/
ENV/

# === Security & Secrets (Zero Trust: Block ALL env files) ===
# ユーザーが誤って自分のAPIキーを公開しないための安全策
.env
.env.*
!.env.example
.dev.vars
secrets.json
*.pem
*.key

# === Editor / IDE (Keep repo clean) ===
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
.history/

# === Output / Logs (Examples often generate these) ===
*.log
output/
data/
tmp/

# === Operating System ===
.DS_Store
Thumbs.db
desktop.ini
